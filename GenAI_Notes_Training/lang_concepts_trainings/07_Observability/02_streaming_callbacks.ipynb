   "source": [
    "def stream_response(chain, query):\n",
    "    # Using .stream() instead of .invoke() yields chunks in real-time\n",
    "    for chunk in chain.stream({\"input\": query}):\n",
    "        print(chunk, end=\"\", flush=True)\n"
   ]
  }
