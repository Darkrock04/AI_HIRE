   "source": [
    "from langchain.tools import tool\n",
    "\n",
    "@tool\n",
    "def calculate_taxes(income: float) -> float:\n",
    "    \"\"\"Useful for calculating taxes on a given numeric income.\"\"\"\n",
    "    return income * 0.20\n",
    "\n",
    "tools = [calculate_taxes]\n"
   ]
  }
